train.root = "data/amazon"
train.split = "beauty"
train.train_test_split = "train"
train.latent_dim = 64
train.hidden_dim = 512
train.num_levels = 3
train.codebook_size = 256
train.num_epochs = 1000
train.batch_size = 640
train.lr = 1e-3
train.weight_decay = 1e-4
train.log_every = 1
train.save_every = 10
train.eval_every_n = 10
train.output_dir = "checkpoints/rqvae/beauty"
train.learnable_codebook=False
